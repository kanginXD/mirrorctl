{
	"name": "mirrorctl dev container",
	"build": {
		"dockerfile": "./Containerfile",
		"context": ".."
	},
	"remoteUser": "dev",
	"remoteEnv": {
		"UV_LINK_MODE": "copy"
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"esbenp.prettier-vscode",
				"charliermarsh.ruff",
				"meta.pyrefly"
			]
		}
	},
	"postCreateCommand": "uv sync --link-mode=copy",
	"postStartCommand": "uv run pre-commit install"
}